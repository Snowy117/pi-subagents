{
  "autoStart": ["typescript"],
  "autoInjectDiagnostics": ["typescript"],
  "servers": {
    "typescript": {
      "command": "typescript-language-server",
      "args": ["--stdio"]
    },
    "typescriptreact": {
      "command": "typescript-language-server",
      "args": ["--stdio"]
    },
    "javascript": {
      "command": "typescript-language-server",
      "args": ["--stdio"]
    },
    "javascriptreact": {
      "command": "typescript-language-server",
      "args": ["--stdio"]
    }
  }
}
